# ==============================================================================
# {COMPANY} Environment Variables
# ==============================================================================
# SECURITY WARNING:
# - Copy to .env and fill in actual values
# - NEVER commit .env to version control
# - Set permissions: chmod 644 .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Cyberbiz (CBZ)
# 取得方式: Cyberbiz 後台 → API 設定
# ------------------------------------------------------------------------------
CBZ_API_TOKEN=your_cyberbiz_api_token
CBZ_SHOP_ID=your_shop_id
CBZ_API_URL=https://api.cyberbiz.io

# ------------------------------------------------------------------------------
# eBay (EBY) - SSH Tunnel + SQL Server
# 取得方式: 客戶提供
# ------------------------------------------------------------------------------
# SSH Tunnel (跳板機)
EBY_SSH_HOST=your_ssh_host_ip
EBY_SSH_USER=your_ssh_username
EBY_SSH_PASSWORD=your_ssh_password
# EBY_SSH_KEY_PATH=~/.ssh/id_eby_{COMPANY}  # 建議改用 key，註解掉上面密碼

# SQL Server (透過 SSH tunnel 連線)
EBY_SQL_HOST=your_sql_server_ip
EBY_SQL_PORT=1433
EBY_LOCAL_PORT=1433
EBY_SQL_DATABASE=your_database_name
EBY_SQL_USER=your_sql_username
EBY_SQL_PASSWORD=your_sql_password

# ------------------------------------------------------------------------------
# Amazon (AMZ)
# 取得方式: AWS Console → IAM → Access Keys
# ------------------------------------------------------------------------------
AMZ_ACCESS_KEY=your_amazon_access_key
AMZ_SECRET_KEY=your_amazon_secret_key
AMZ_REGION=us-west-2

# ------------------------------------------------------------------------------
# OpenAI
# 取得方式: https://platform.openai.com/api-keys
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key

# ------------------------------------------------------------------------------
# Supabase (app_data deployment)
# 取得方式: Supabase Dashboard → Project Settings → Database
# 對應 app_config.yaml 的 supabase.db.*_env
# ------------------------------------------------------------------------------
SUPABASE_DB_HOST=your_supabase_host
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=your_supabase_user
SUPABASE_DB_PASSWORD=your_supabase_password

# ------------------------------------------------------------------------------
# PostgreSQL (如使用外部 DB，非 Supabase)
# ------------------------------------------------------------------------------
PGHOST=your_postgres_host
PGPORT=5432
PGDATABASE=your_database_name
PGUSER=your_postgres_username
PGPASSWORD=your_postgres_password
PGSSLMODE=require

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=info
APP_PASSWORD=c("VIBE")
