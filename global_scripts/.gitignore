# =============================================================================
# Archive Version Control Policy
# =============================================================================
# 99_archive/ is the ONLY archive directory under version control.
# It contains curated, organized historical documents.
# All other archive*/ directories anywhere in the tree are local-only
# (staging buffers, in-place archives, temp work) and excluded from Git.
# See: SO_R006 Archiving Standard Rule, Section 8 (Version Control Policy)
# =============================================================================

# Ignore all archive-like directories everywhere in the tree
**/archive*/
**/_archive*/
**/*_archived*/

# EXCEPT: keep 99_archive (curated historical archive, the single source of truth)
!99_archive/
!99_archive/**

# System files
.DS_Store
