# Quarto Ignore File
# Files and directories to exclude from Quarto rendering

# Operational directories (not part of the book)
CHANGELOG/
ISSUE_TRACKER/
REFERENCES/
CURSOR_RULES/

# Archive and backup directories
archive/
**/archive/

# Templates (source files, not content)
templates/

# Claude configuration
.claude/

# Build artifacts
_book/
_freeze/
.quarto/

# System files
.DS_Store
*.backup*
*.log

# R/Python artifacts
*.rds
*.RData
*.Rhistory

# Temporary files
*.tmp
*.temp
*~

# Reports and summaries (operational, not principles)
*_REPORT*.md
*_SUMMARY*.md
*DEBUG*.md
ROOT_*.md
QUARTO_*.md
