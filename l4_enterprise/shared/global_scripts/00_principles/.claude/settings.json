{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash .claude/hooks/archive-plan.sh",
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      },
      {
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-principle-sync.sh",
            "statusMessage": "Checking principle triple-layer sync (DOC_R009)...",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-wiki-sync.sh",
            "statusMessage": "Checking Wiki sync requirements (DOC_R006)...",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-issue.sh",
            "statusMessage": "Checking GitHub Issue association (IC_R009)...",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-tbl2-compliance.sh",
            "statusMessage": "Checking tbl2 compliance (DM_R023)...",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dropbox-git-ignore.sh",
            "statusMessage": "Checking Dropbox git protection...",
            "type": "command"
          }
        ]
      }
    ]
  },
  "includeGitInstructions": false
}