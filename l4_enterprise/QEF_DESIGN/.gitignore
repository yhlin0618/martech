# R files
.Rhistory
.RData
.Rproj.user/
.Ruserdata

# Environment files
.env
!.env.template

# Data files
*.sqlite
*.db
*.duckdb

# System files
.DS_Store
Thumbs.db

# Enterprise data directories - IMPORTANT: Keep these private!
data/database_to_csv/
data/local_data/
# Allow app_data directory for deployment
!data/app_data/*

# But keep local DuckDB and OS metadata ignored (may contain private data)
data/app_data/*.duckdb
data/app_data/.DS_Store

# Local runtime caches
cache/
.cache/

# Logs
logs/

# Output
output/

# Validation
validation/

# Archives and backups
archive/

# Keep global_scripts principle docs archives versioned
!scripts/global_scripts/00_principles/archive/
!scripts/global_scripts/00_principles/archive/docs_archived/
!scripts/global_scripts/00_principles/archive/docs_archived/**

# Workspace files
*.code-workspace

# Generated config (from make config-merge)
_targets_config.yaml

# Targets cache (regenerated on run)
_targets/

# Local Shiny debug artifacts (runtime only)
.shiny-debug/
