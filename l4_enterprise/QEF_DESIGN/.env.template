# ==============================================================================
# QEF_DESIGN Environment Variables
# ==============================================================================
# SECURITY WARNING:
# - Copy to .env and fill in actual values
# - NEVER commit .env to version control
# - Set permissions: chmod 600 .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Amazon (AMZ)
# 取得方式: AWS Console → IAM → Access Keys
# ------------------------------------------------------------------------------
AMZ_ACCESS_KEY=your_amazon_access_key
AMZ_SECRET_KEY=your_amazon_secret_key
AMZ_REGION=us-west-2

# ------------------------------------------------------------------------------
# OpenAI
# 取得方式: https://platform.openai.com/api-keys
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key

# ------------------------------------------------------------------------------
# Supabase (app_data deployment)
# 取得方式: Supabase Dashboard → Project Settings → Database
# 對應 app_config.yaml 的 supabase.db.*_env
# ------------------------------------------------------------------------------
SUPABASE_DB_HOST=your_supabase_host
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=your_supabase_user
SUPABASE_DB_PASSWORD=your_supabase_password

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=info
