# ============================================================
# ai_martech .gitignore
# ============================================================

# ------------------------------------------------------------
# R / RStudio
# ------------------------------------------------------------
.Rhistory
.RData
.Rprofile.local
.Rprofile.user
.Rproj.user/
.Ruserdata
*.Rcheck/
.httr-oauth

# ------------------------------------------------------------
# Environment & secrets
# ------------------------------------------------------------
.env
.env.*
.Renviron
credentials.json

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*~

# ------------------------------------------------------------
# IDE / Editor
# ------------------------------------------------------------
.vscode/
*.code-workspace
.idea/

# ------------------------------------------------------------
# Database files
# ------------------------------------------------------------
*.duckdb
*.duckdb.wal
*.sqlite
*.sqlite3
*.db

# ------------------------------------------------------------
# Data files
# ------------------------------------------------------------
*.csv
*.tsv
*.xlsx
*.xls
*.feather
*.parquet
*.rds
*.RData
*.sav
*.sas7bdat

# ------------------------------------------------------------
# Archive / compressed files
# ------------------------------------------------------------
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z

# ------------------------------------------------------------
# Media files
# ------------------------------------------------------------
*.mp3
*.mp4
*.wav
*.m4a
*.mov
*.avi
*.srt

# ------------------------------------------------------------
# Documents (binary)
# ------------------------------------------------------------
*.pdf
*.docx
*.pptx
*.doc
*.ppt

# ------------------------------------------------------------
# Images (large collections)
# ------------------------------------------------------------
*.jpg
*.JPG
*.jpeg
*.JPEG

# ------------------------------------------------------------
# Backup & temp files
# ------------------------------------------------------------
*.bak
*.backup_drv_*
*.log
*.tmp

# ------------------------------------------------------------
# Dropbox conflict copies
# ------------------------------------------------------------
*衝突的複本*
*conflicted copy*

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ------------------------------------------------------------
# R deployment (auto-generated)
# ------------------------------------------------------------
manifest.json
rsconnect/
packrat/
renv/
renv.lock

# ------------------------------------------------------------
# Directories: archive, data, backups
# ------------------------------------------------------------
archive/
**/data/
**/backups/
**/backup/
**/database/

# ------------------------------------------------------------
# Archived / historical code
# ------------------------------------------------------------
**/99_archive/
**/CHANGELOG/
**/renumbering_backup/

# ------------------------------------------------------------
# Subrepo synced copies (canonical: root global_scripts/)
# ------------------------------------------------------------
**/scripts/global_scripts/
**/scripts/global_data/
l4_enterprise/shared/global_scripts/
l3_premium/scripts/

# ------------------------------------------------------------
# Sandbox / dev test environments
# ------------------------------------------------------------
l3_premium/sandbox/

# ------------------------------------------------------------
# Large / non-code directories
# ------------------------------------------------------------
l9_projects/
docs/communications/
docs/records/
docs/presentations/
docs/suggestion/

# ------------------------------------------------------------
# Node
# ------------------------------------------------------------
node_modules/

# ------------------------------------------------------------
# Deployment whitelist (override above rules for Posit Connect)
# ------------------------------------------------------------
!l1_basic/TagPilot/database/
!l1_basic/TagPilot/scripts/global_scripts/
!l1_basic/TagPilot/manifest.json
